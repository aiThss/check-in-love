# =============================================================================
# LoveCheck — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# --- API Server ---
NODE_ENV=production
PORT=3001

# MongoDB connection string
# Local docker: mongodb://mongo:27017/checkinlove
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/checkinlove
MONGODB_URI=mongodb://mongo:27017/checkinlove

# JWT secret — must be at least 32 random characters
JWT_SECRET=change_me_to_a_very_long_random_string_min_32_chars

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_password

# Enables destructive admin-only reset endpoint for repeated testing.
# Keep false in production.
ADMIN_ENABLE_TEST_RESET=false

# Public base URL for API (used in file URLs etc.)
PUBLIC_BASE_URL=https://api.couple.babyress.games

# Upload directory (inside container, mapped to a Docker volume)
UPLOAD_DIR=/app/uploads

# Max upload size in MB
MAX_UPLOAD_MB=10

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://couple.babyress.games,https://admin.couple.babyress.games

# --- Web Push (Optional — generate with: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com

# --- PWA ---
VITE_API_URL=https://api.couple.babyress.games/api

# --- Admin ---
# (Admin uses same VITE_API_URL — set per-service in docker-compose)
